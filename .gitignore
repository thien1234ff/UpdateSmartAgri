.vercel
node_modules
# Tạo/tạo mới .gitignore
cat > .gitignore << 'EOL'
# Dependencies
node_modules/
/.pnp
.pnp.js
.next/
.next/cache/

# Production
/build
/out

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# Large media files
*.mp4
*.mov
*.avi
*.mkv
*.pack
*.node

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
serviceAccountKey.json
EOL